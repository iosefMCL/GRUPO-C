        cout << "=================================\n";
        cout << "1. Registrar estudiante\n";
        cout << "2. Ver estudiantes\n";
        cout << "3. Modificar estudiante\n";
        cout << "4. Eliminar estudiante\n";
        cout << "5. Guardar datos\n";
        cout << "6. Cargar datos\n";
        cout << "7. Ver cola\n";
        cout << "8. Procesar matricula\n";
        cout << "9. Ver historial\n";
        cout << "10. POP historial\n";
        cout << "11. Ver carreras\n";
        cout << "12. Salir\n";
        cout << "Opcion: ";

        cin >> opcion;

        switch(opcion)
        {
            case 1:
                registrarEstudiante();
                break;

            case 2:
                mostrarEstudiantes();
                break;

            case 3:
                modificarEstudiante();
                break;

            case 4:
                eliminarEstudiante();
                break;

            case 5:
                guardarDatos();
                break;

            case 6:
                cargarDatos();
                break;

            case 7:
                mostrarCola();
                break;

            case 8:
                procesarMatricula();
                break;

            case 9:
                mostrarHistorial();
                break;

            case 10:
                pop();
                break;

            case 11:
                mostrarCarreras();
                break;

            case 12:
                cout << "\nFin del programa.\n";
                break;

            default:
                cout << "\nOpcion invalida.\n";
        }

    } while(opcion != 12);

    return 0;
}
